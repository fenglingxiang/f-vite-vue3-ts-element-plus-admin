{
  "name": "nestjs-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "commit": "git-cz",
    "prepare": "husky install && chmod +x .husky/commit-msg "
  },
  "dependencies": {
    "@antdv-next/icons": "^1.0.6",
    "@tailwindcss/vite": "^4.2.3",
    "antdv-next": "^1.2.1",
    "axios": "^1.15.1",
    "normalize.css": "^8.0.1",
    "pinia": "^3.0.4",
    "qs": "^6.15.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@antdv-next/auto-import-resolver": "^1.0.7",
    "@antdv-next/tailwind": "^1.0.2",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^24.12.2",
    "@types/qs": "^6.15.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.4",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sass": "^1.99.0",
    "tailwindcss": "^4.2.3",
    "tailwindcss-scoped-preflight": "^4.0.1",
    "typescript": "~6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.9",
    "vue-tsc": "^3.2.7"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": ".cz-config.cjs"
    }
  }
}
